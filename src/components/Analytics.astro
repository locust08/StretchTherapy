---
const publicGtmId =
  import.meta.env.PUBLIC_GTM_ID ||
  import.meta.env.PUBLIC_GTM_CONTAINER_ID ||
  import.meta.env.NEXT_PUBLIC_GTM_ID ||
  import.meta.env.NEXT_PUBLIC_GTM_CONTAINER_ID ||
  import.meta.env.GTM_CONTAINER_ID ||
  '';
const publicGa4MeasurementId =
  import.meta.env.PUBLIC_GA4_MEASUREMENT_ID ||
  import.meta.env.NEXT_PUBLIC_GA4_MEASUREMENT_ID ||
  '';

const gtmId = /^GTM-[A-Z0-9]+$/i.test(publicGtmId) ? publicGtmId : '';
const ga4MeasurementId = /^G-[A-Z0-9]+$/i.test(publicGa4MeasurementId)
  ? publicGa4MeasurementId
  : '';
---

<script is:inline define:vars={{ ga4MeasurementId, gtmId }}>
  (() => {
    const hasGtm = Boolean(gtmId);
    const hasDirectGa4 = !hasGtm && Boolean(ga4MeasurementId);

    if (hasGtm) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        'gtm.start': Date.now(),
        event: 'gtm.js',
      });

      const firstScript = document.getElementsByTagName('script')[0];
      const gtmScript = document.createElement('script');
      const dataLayerName = 'dataLayer';

      gtmScript.async = true;
      gtmScript.src =
        'https://www.googletagmanager.com/gtm.js?id=' +
        encodeURIComponent(gtmId) +
        '&l=' +
        dataLayerName;
      firstScript?.parentNode?.insertBefore(gtmScript, firstScript);
    } else if (hasDirectGa4) {
      window.dataLayer = window.dataLayer || [];
      window.gtag = function gtag() {
        window.dataLayer.push(arguments);
      };
      window.gtag('js', new Date());
      window.gtag('config', ga4MeasurementId);

      const firstScript = document.getElementsByTagName('script')[0];
      const gaScript = document.createElement('script');
      gaScript.async = true;
      gaScript.src =
        'https://www.googletagmanager.com/gtag/js?id=' +
        encodeURIComponent(ga4MeasurementId);
      firstScript?.parentNode?.insertBefore(gaScript, firstScript);
    }

    const linkEvents = [
      {
        event: 'whatsapp_click',
        matches: (url) =>
          ['wa.me', 'api.whatsapp.com', 'web.whatsapp.com'].includes(url.hostname) ||
          url.protocol === 'whatsapp:',
      },
      {
        event: 'facebook_click',
        matches: (url) =>
          ['facebook.com', 'fb.com', 'm.facebook.com', 'www.facebook.com'].includes(
            url.hostname,
          ),
      },
      {
        event: 'x_click',
        matches: (url) =>
          ['x.com', 'www.x.com', 'twitter.com', 'www.twitter.com'].includes(
            url.hostname,
          ),
      },
      {
        event: 'instagram_click',
        matches: (url) =>
          ['instagram.com', 'www.instagram.com'].includes(url.hostname),
      },
      {
        event: 'tiktok_click',
        matches: (url) => ['tiktok.com', 'www.tiktok.com'].includes(url.hostname),
      },
      {
        event: 'linkedin_click',
        matches: (url) =>
          ['linkedin.com', 'www.linkedin.com'].includes(url.hostname),
      },
      {
        event: 'google_maps_click',
        matches: (url) =>
          ((url.hostname === 'google.com' || url.hostname === 'www.google.com') &&
            url.pathname.startsWith('/maps')) ||
          url.hostname === 'maps.google.com' ||
          (url.hostname === 'goo.gl' && url.pathname.startsWith('/maps')) ||
          url.hostname === 'maps.app.goo.gl',
      },
      {
        event: 'waze_click',
        matches: (url) =>
          ['waze.com', 'www.waze.com', 'ul.waze.com'].includes(url.hostname) ||
          url.protocol === 'waze:',
      },
    ];

    const cleanText = (value) => value.trim().replace(/\s+/g, ' ').slice(0, 120);

    const trackEvent = (eventName, payload) => {
      const eventPayload = {
        ...payload,
        page_path: window.location.pathname,
      };

      if (hasGtm) {
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: eventName,
          ...eventPayload,
        });
        return;
      }

      if (hasDirectGa4 && typeof window.gtag === 'function') {
        window.gtag('event', eventName, eventPayload);
      }
    };

    const eventForHref = (href, baseUrl) => {
      if (!href) return null;

      try {
        const url = new URL(href, baseUrl);
        const match = linkEvents.find((linkEvent) => linkEvent.matches(url));
        return match ? { eventName: match.event, url } : null;
      } catch {
        return null;
      }
    };

    const attachTracking = (doc) => {
      if (!doc || doc.__stretchTherapyAnalyticsAttached) return;
      doc.__stretchTherapyAnalyticsAttached = true;

      doc.addEventListener('click', (event) => {
        const link = event.target?.closest?.('a[href]');
        if (!link) return;

        const match = eventForHref(link.getAttribute('href'), doc.location.href);
        if (!match) return;

        trackEvent(match.eventName, {
          link_url: match.url.href,
          link_text: cleanText(link.textContent || link.getAttribute('aria-label') || ''),
        });
      });

      doc.addEventListener('submit', (event) => {
        const form = event.target;
        if (form?.tagName !== 'FORM') return;

        window.setTimeout(() => {
          if (event.defaultPrevented) return;

          trackEvent('lead_form_submit', {
            form_id: form.id || undefined,
            form_name: form.getAttribute('name') || undefined,
          });
        }, 0);
      });
    };

    const attachIframeTracking = () => {
      document.querySelectorAll('iframe').forEach((iframe) => {
        iframe.addEventListener('load', () => {
          try {
            attachTracking(iframe.contentDocument);
          } catch {
            // Cross-origin forms such as Zoho /join cannot be inspected safely.
          }
        });

        try {
          attachTracking(iframe.contentDocument);
        } catch {
          // Cross-origin frames are intentionally skipped.
        }
      });
    };

    attachTracking(document);

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', attachIframeTracking, { once: true });
    } else {
      attachIframeTracking();
    }
  })();
</script>
