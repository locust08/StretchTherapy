---
import fs from 'node:fs/promises';
import path from 'node:path';
import TrackingHead from '../components/TrackingHead.astro';
import TrackingNoScript from '../components/TrackingNoScript.astro';

const baseDir = path.join(process.cwd(), 'public', 'reference', "contact");
const head = JSON.parse(await fs.readFile(path.join(baseDir, 'head.json'), 'utf8'));
const sourceUrl = "https://stretchtherapy.my/contact/";
const routeMap = {
  "https://stretchtherapy.my/": "/",
  "https://stretchtherapy.my/about": "/about",
  "https://stretchtherapy.my/first-timers": "/first-timers",
  "https://stretchtherapy.my/classes": "/classes",
  "https://stretchtherapy.my/reviews": "/reviews",
  "https://stretchtherapy.my/contact": "/contact",
  "https://stretchtherapy.my/privacy-policy": "/privacy-policy",
  "https://stretchtherapy.my/corporate": "/corporate"
};
const framePath = '/reference/contact/index.html';
---

<html>
  <head>
    <title>{head.title}</title>
    {head.metas?.map((meta) => <meta {...meta} />)}
    {head.links?.map((link) => <link {...link} />)}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <TrackingHead />
    <style>
      html, body {
        margin: 0;
        height: 100%;
      }

      iframe {
        width: 100%;
        height: 100vh;
        border: 0;
        display: block;
      }

    </style>
  </head>
  <body>
    <TrackingNoScript />
    <section aria-label="Page heading structure" style="position:absolute !important;width:1px !important;height:1px !important;margin:-1px !important;padding:0 !important;overflow:hidden !important;clip:rect(0 0 0 0) !important;clip-path:inset(50%) !important;white-space:nowrap !important;border:0 !important;">
      <h1>Contact Us</h1>
      <h2>Contact Stretch Therapy Centre</h2>
      <h2>WhatsApp enquiries and private assessment bookings</h2>
      <h2>Petaling Jaya studio address</h2>
    </section>
    <iframe id="page-frame" src={framePath}></iframe>
    <script is:inline>
      const iframe = document.getElementById('page-frame');
      const sourceUrlValue = "https://stretchtherapy.my/contact/";
      const routeMapValue = {
  "https://stretchtherapy.my/": "/",
  "https://stretchtherapy.my/about": "/about",
  "https://stretchtherapy.my/first-timers": "/first-timers",
  "https://stretchtherapy.my/classes": "/classes",
  "https://stretchtherapy.my/reviews": "/reviews",
  "https://stretchtherapy.my/contact": "/contact",
  "https://stretchtherapy.my/privacy-policy": "/privacy-policy",
  "https://stretchtherapy.my/corporate": "/corporate"
};

      const normalizeTarget = (href) => {
        if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) {
          return null;
        }

        try {
          const resolvedUrl = new URL(href, sourceUrlValue);
          const pathname = resolvedUrl.pathname.replace(/\/+$/, '') || '/';
          return resolvedUrl.origin + pathname;
        } catch {
          return null;
        }
      };

      const localRouteForHref = (href) => {
        const normalizedTarget = normalizeTarget(href);
        if (!normalizedTarget) return null;
        return routeMapValue[normalizedTarget] || null;
      };

      const trackOutboundClick = (link) => {
        const href = link.getAttribute('href');
        if (!href) return;

        let resolvedUrl;
        try {
          resolvedUrl = new URL(href, sourceUrlValue);
        } catch {
          return;
        }

        const host = resolvedUrl.hostname.replace(/^www\./, '');
        const text = link.textContent?.trim() || link.getAttribute('aria-label') || '';
        const commonParams = {
          link_url: resolvedUrl.href,
          link_text: text,
          page_location: window.location.href,
        };

        if (host === 'wa.me' || host.includes('whatsapp.com')) {
          window.trackStretchTherapyEvent?.('whatsapp_click', commonParams);
        } else if (host === 'facebook.com' || host === 'fb.com') {
          window.trackStretchTherapyEvent?.('facebook_click', commonParams);
        } else if (host === 'instagram.com') {
          window.trackStretchTherapyEvent?.('instagram_click', commonParams);
        } else if (host.includes('google.') && resolvedUrl.href.includes('/maps')) {
          window.trackStretchTherapyEvent?.('google_maps_click', commonParams);
        }
      };

      const bindGoogleMapsFrames = (root) => {
        root.querySelectorAll?.('iframe[src*="maps.google"]').forEach((mapFrame) => {
          if (mapFrame.dataset.stretchtherapyTracked === 'true') return;
          mapFrame.dataset.stretchtherapyTracked = 'true';

          const wrapper = mapFrame.ownerDocument.createElement('div');
          wrapper.style.position = 'relative';
          wrapper.style.display = 'block';
          wrapper.style.width = '100%';
          wrapper.style.height = mapFrame.style.height || `${mapFrame.offsetHeight || 450}px`;

          const openMapsLink = mapFrame.ownerDocument.createElement('a');
          openMapsLink.href = 'https://www.google.com/maps/search/?api=1&query=Stretch%20Therapy%2C%201st%20Floor%2C%2029%2C%20Jalan%20SS';
          openMapsLink.target = '_blank';
          openMapsLink.rel = 'noopener';
          openMapsLink.textContent = 'Open in Maps';
          openMapsLink.setAttribute('aria-label', 'Open Stretch Therapy in Google Maps');
          openMapsLink.style.position = 'absolute';
          openMapsLink.style.top = '12px';
          openMapsLink.style.left = '12px';
          openMapsLink.style.zIndex = '2';
          openMapsLink.style.display = 'inline-flex';
          openMapsLink.style.alignItems = 'center';
          openMapsLink.style.gap = '8px';
          openMapsLink.style.minHeight = '42px';
          openMapsLink.style.boxSizing = 'border-box';
          openMapsLink.style.padding = '0 14px';
          openMapsLink.style.border = '0';
          openMapsLink.style.borderRadius = '2px';
          openMapsLink.style.background = '#fff';
          openMapsLink.style.color = '#1a73e8';
          openMapsLink.style.font = '500 18px Roboto, Arial, sans-serif';
          openMapsLink.style.lineHeight = '1';
          openMapsLink.style.textDecoration = 'none';
          openMapsLink.style.whiteSpace = 'nowrap';
          openMapsLink.style.boxShadow = '0 1px 4px -1px rgba(0,0,0,.3)';

          const externalIcon = mapFrame.ownerDocument.createElementNS('http://www.w3.org/2000/svg', 'svg');
          externalIcon.setAttribute('viewBox', '0 0 24 24');
          externalIcon.setAttribute('width', '18');
          externalIcon.setAttribute('height', '18');
          externalIcon.setAttribute('fill', 'none');
          externalIcon.setAttribute('stroke', 'currentColor');
          externalIcon.setAttribute('stroke-width', '2');
          externalIcon.setAttribute('stroke-linecap', 'round');
          externalIcon.setAttribute('stroke-linejoin', 'round');
          externalIcon.style.flex = '0 0 auto';
          externalIcon.setAttribute('aria-hidden', 'true');
          const iconPath = mapFrame.ownerDocument.createElementNS('http://www.w3.org/2000/svg', 'path');
          iconPath.setAttribute('d', 'M14 3h7v7h-2V6.41l-9.83 9.83-1.41-1.41L17.59 5H14V3z M5 5h6v2H7v10h10v-4h2v6H5V5z');
          externalIcon.setAttribute('fill', 'currentColor');
          externalIcon.setAttribute('stroke', 'none');
          externalIcon.appendChild(iconPath);
          openMapsLink.appendChild(externalIcon);

          mapFrame.parentNode.insertBefore(wrapper, mapFrame);
          wrapper.appendChild(mapFrame);
          wrapper.appendChild(openMapsLink);
        });
      };

      const rewriteLinks = (root) => {
        root.querySelectorAll?.('a[href]').forEach((link) => {
          const localRoute = localRouteForHref(link.getAttribute('href'));
          if (!localRoute) return;

          link.setAttribute('href', localRoute);
          link.setAttribute('target', '_top');
        });

        bindGoogleMapsFrames(root);
      };

      iframe?.addEventListener('load', () => {
        const iframeWindow = iframe.contentWindow;
        const iframeDocument = iframe.contentDocument;
        if (!iframeWindow || !iframeDocument) return;

        rewriteLinks(iframeDocument);

        const observer = new iframeWindow.MutationObserver((mutations) => {
          for (const mutation of mutations) {
            mutation.addedNodes.forEach((node) => {
              if (node.nodeType === iframeWindow.Node.ELEMENT_NODE) {
                rewriteLinks(node);
              }
            });
          }
        });

        if (iframeDocument.documentElement) {
          observer.observe(iframeDocument.documentElement, {
            childList: true,
            subtree: true,
          });
        }

        iframeDocument.addEventListener('click', (event) => {
          const link = event.target.closest?.('a[href]');
          if (!link) return;

          trackOutboundClick(link);

          const localRoute = localRouteForHref(link.getAttribute('href'));
          if (!localRoute) return;

          event.preventDefault();
          window.location.assign(localRoute);
        });
      });
    </script>
  </body>
</html>

