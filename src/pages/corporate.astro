---
import fs from 'node:fs/promises';
import path from 'node:path';
import TrackingHead from '../components/TrackingHead.astro';
import TrackingNoScript from '../components/TrackingNoScript.astro';

const baseDir = path.join(process.cwd(), 'public', 'reference', "corporate");
const head = JSON.parse(await fs.readFile(path.join(baseDir, 'head.json'), 'utf8'));
const sourceUrl = "https://stretchtherapy.my/corporate/";
const routeMap = {
  "https://stretchtherapy.my/": "/",
  "https://stretchtherapy.my/about": "/about",
  "https://stretchtherapy.my/first-timers": "/first-timers",
  "https://stretchtherapy.my/classes": "/classes",
  "https://stretchtherapy.my/reviews": "/reviews",
  "https://stretchtherapy.my/contact": "/contact",
  "https://stretchtherapy.my/privacy-policy": "/privacy-policy",
  "https://stretchtherapy.my/corporate": "/corporate"
};
const framePath = '/reference/corporate/index.html';
---

<html lang="en">
  <head>
    <title>{head.title}</title>
    {head.metas?.map((meta) => <meta {...meta} />)}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <TrackingHead />
    <style>
      html, body {
        margin: 0;
        height: 100%;
      }

      iframe {
        width: 100%;
        height: 100vh;
        border: 0;
        display: block;
      }

    </style>
  </head>
  <body>
    <TrackingNoScript />
    <section aria-label="Page heading structure" style="position:absolute !important;width:1px !important;height:1px !important;margin:-1px !important;padding:0 !important;overflow:hidden !important;clip:rect(0 0 0 0) !important;clip-path:inset(50%) !important;white-space:nowrap !important;border:0 !important;">
      <h1>Resilient Teams, Healthier People, Stronger Performance</h1>
      <h2>Build resilience as a team through our corporate training programmes</h2>
      <h2>Trusted by corporate teams</h2>
      <h2>Self-care, stress regulation and healthier workplace performance</h2>
    </section>
    <iframe id="page-frame" src={framePath} title="Stretch Therapy corporate page content"></iframe>
    <script is:inline>
      const iframe = document.getElementById('page-frame');
      const sourceUrlValue = "https://stretchtherapy.my/corporate/";
      const routeMapValue = {
  "https://stretchtherapy.my/": "/",
  "https://stretchtherapy.my/about": "/about",
  "https://stretchtherapy.my/first-timers": "/first-timers",
  "https://stretchtherapy.my/classes": "/classes",
  "https://stretchtherapy.my/reviews": "/reviews",
  "https://stretchtherapy.my/contact": "/contact",
  "https://stretchtherapy.my/privacy-policy": "/privacy-policy",
  "https://stretchtherapy.my/corporate": "/corporate"
};

      const normalizeTarget = (href) => {
        if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) {
          return null;
        }

        try {
          const resolvedUrl = new URL(href, sourceUrlValue);
          const pathname = resolvedUrl.pathname.replace(/\/+$/, '') || '/';
          return resolvedUrl.origin + pathname;
        } catch {
          return null;
        }
      };

      const localRouteForHref = (href) => {
        const normalizedTarget = normalizeTarget(href);
        if (!normalizedTarget) return null;
        return routeMapValue[normalizedTarget] || null;
      };

      const trackOutboundClick = (link) => {
        const href = link.getAttribute('href');
        if (!href) return;

        let resolvedUrl;
        try {
          resolvedUrl = new URL(href, sourceUrlValue);
        } catch {
          return;
        }

        const host = resolvedUrl.hostname.replace(/^www\./, '');
        const text = link.textContent?.trim() || link.getAttribute('aria-label') || '';
        const commonParams = {
          link_url: resolvedUrl.href,
          link_text: text,
          page_location: window.location.href,
        };

        if (host === 'wa.me' || host.includes('whatsapp.com')) {
          window.trackStretchTherapyEvent?.('whatsapp_click', commonParams);
        } else if (host === 'facebook.com' || host === 'fb.com') {
          window.trackStretchTherapyEvent?.('facebook_click', commonParams);
        } else if (host === 'instagram.com') {
          window.trackStretchTherapyEvent?.('instagram_click', commonParams);
        } else if (host.includes('google.') && resolvedUrl.href.includes('/maps')) {
          window.trackStretchTherapyEvent?.('google_maps_click', commonParams);
        }
      };

      const trackLeadFormSubmit = (form) => {
        const action = form.getAttribute('action') || '';
        if (!action.includes('forms.zohopublic.com')) return;

        window.trackStretchTherapyEvent?.('lead_form_submit', {
          page_location: window.location.href,
          form_action: action,
          form_context: 'corporate',
          form_provider: 'zoho',
        });
      };

      const rewriteLinks = (root) => {
        root.querySelectorAll?.('a[href]').forEach((link) => {
          const localRoute = localRouteForHref(link.getAttribute('href'));
          if (!localRoute) return;

          link.setAttribute('href', localRoute);
          link.setAttribute('target', '_top');
        });
      };

      iframe?.addEventListener('load', () => {
        const iframeWindow = iframe.contentWindow;
        const iframeDocument = iframe.contentDocument;
        if (!iframeWindow || !iframeDocument) return;

        rewriteLinks(iframeDocument);

        const observer = new iframeWindow.MutationObserver((mutations) => {
          for (const mutation of mutations) {
            mutation.addedNodes.forEach((node) => {
              if (node.nodeType === iframeWindow.Node.ELEMENT_NODE) {
                rewriteLinks(node);
              }
            });
          }
        });

        if (iframeDocument.documentElement) {
          observer.observe(iframeDocument.documentElement, {
            childList: true,
            subtree: true,
          });
        }

        iframeDocument.addEventListener('click', (event) => {
          const link = event.target.closest?.('a[href]');
          if (!link) return;

          trackOutboundClick(link);

          const localRoute = localRouteForHref(link.getAttribute('href'));
          if (!localRoute) return;

          event.preventDefault();
          window.location.assign(localRoute);
        });

        iframeDocument.addEventListener('submit', (event) => {
          const form = event.target?.closest?.('form');
          if (form) trackLeadFormSubmit(form);
        }, true);
      });
    </script>
  </body>
</html>
